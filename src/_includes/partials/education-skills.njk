<section class="skills-dashboard">
  <h2 data-i18n="education.title">Education &amp; Skills</h2>
  <div class="about-underline" role="presentation"></div>
  <p class="work-intro" data-i18n="education.intro">Academic background and core technical strengths.</p>
  <h3 class="section-title education-focus-title" data-i18n="education.focus.title">Core Focus</h3>
  <p class="work-intro education-focus-copy" data-i18n="education.focus.copy">
   Full-stack development with .NET and modern frontend technologies,
focused on building scalable and user-friendly applications.
  </p>

  <div class="skills-dashboard-grid">
    <article class="skills-panel">
      <h3 class="skills-panel-heading">
        <span class="skills-panel-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 7h16M4 12h16M4 17h10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </span>
        <span class="skills-panel-title" data-i18n="education.section.skills">Skills</span>
      </h3>
      <div class="skills-chip-wrap">
        <span class="skills-chip" data-i18n="education.skills.item1">Clean Architecture</span>
        <span class="skills-chip" data-i18n="education.skills.item2">REST API Development (ASP.NET Core)</span>
        <span class="skills-chip" data-i18n="education.skills.item3">Entity Framework & Database Design</span>
        <span class="skills-chip" data-i18n="education.skills.item4">Component-based UI (Angular)</span>
        <span class="skills-chip" data-i18n="education.skills.item5">Responsive &amp; Accessible UI</span>
       
      </div>
    </article>

    <article class="skills-panel language-skills-panel">
      <h3 class="skills-panel-heading">
        <span class="skills-panel-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 3.5A8.5 8.5 0 1 0 20.5 12 8.5 8.5 0 0 0 12 3.5Zm0 0c2.3 2.4 3.4 5.2 3.4 8.5S14.3 18.1 12 20.5M12 3.5c-2.3 2.4-3.4 5.2-3.4 8.5s1.1 6.1 3.4 8.5M4.7 9.4h14.6M4.7 14.6h14.6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <span class="skills-panel-title" data-i18n="education.section.languages">Language Skills</span>
      </h3>
      <div class="skills-chip-wrap">
        <span class="skills-chip" data-i18n="education.languages.item1">English</span>
        <span class="skills-chip" data-i18n="education.languages.item2">Swedish</span>
        <span class="skills-chip" data-i18n="education.languages.item3">Tigrinja</span>
        <span class="skills-chip" data-i18n="education.languages.item4">Arabic</span>
      </div>
    </article>

    <article class="skills-panel">
      <h3 class="skills-panel-heading">
        <span class="skills-panel-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 8h14M5 12h14M5 16h14" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
            <circle cx="8" cy="8" r="1.2" fill="currentColor" />
            <circle cx="16" cy="12" r="1.2" fill="currentColor" />
            <circle cx="11" cy="16" r="1.2" fill="currentColor" />
          </svg>
        </span>
        <span class="skills-panel-title" data-i18n="education.section.technical">Technical Skills</span>
      </h3>
      <div class="skills-tech-groups">
        <section class="skills-tech-group">
          <h4 class="skills-tech-group-title" data-i18n="education.tech.backend">Backend</h4>
          <div class="skills-chip-wrap">
            <span class="skills-chip" data-i18n="education.tech.backend.item1">C# / .NET</span>
            <span class="skills-chip" data-i18n="education.tech.backend.item2">ASP.NET Core MVC</span>
            <span class="skills-chip" data-i18n="education.tech.backend.item3">Entity Framework Core</span>
            <span class="skills-chip" data-i18n="education.tech.backend.item4">ASP.NET Identity</span>
            <span class="skills-chip" data-i18n="education.tech.backend.item5">REST API design</span>
            <span class="skills-chip" data-i18n="education.tech.backend.item6">Role-based access control</span>
          </div>
        </section>

        <section class="skills-tech-group">
          <h4 class="skills-tech-group-title" data-i18n="education.tech.frontend">Frontend</h4>
          <div class="skills-chip-wrap">
            <span class="skills-chip" data-i18n="education.tech.frontend.item1">TypeScript</span>
            <span class="skills-chip" data-i18n="education.tech.frontend.item2">Angular</span>
            <span class="skills-chip" data-i18n="education.tech.frontend.item5">Component-based UI architecture</span>
            <span class="skills-chip" data-i18n="education.tech.frontend.item6">Responsive design</span>
          </div>
        </section>

        <section class="skills-tech-group">
          <h4 class="skills-tech-group-title" data-i18n="education.tech.databases">Databases</h4>
          <div class="skills-chip-wrap">
            <span class="skills-chip" data-i18n="education.tech.databases.item1">SQL Server</span>
            <span class="skills-chip" data-i18n="education.tech.databases.item2">PostgreSQL</span>
            <span class="skills-chip" data-i18n="education.tech.databases.item3">SQLite</span>
            <span class="skills-chip" data-i18n="education.tech.databases.item4">Schema design &amp; relational modeling</span>
          </div>
        </section>

        <section class="skills-tech-group">
          <h4 class="skills-tech-group-title" data-i18n="education.tech.tools">Tools &amp; Environment</h4>
          <div class="skills-chip-wrap">
            <span class="skills-chip" data-i18n="education.tech.tools.item1">Git / GitHub</span>
            <span class="skills-chip" data-i18n="education.tech.tools.item2">Supabase</span>
            <span class="skills-chip" data-i18n="education.tech.tools.item5">Vercel / Netlify (explored)</span>
          </div>
        </section>
      </div>
    </article>

    <article class="skills-panel">
      <h3 class="skills-panel-heading">
        <span class="skills-panel-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M3 8.5 12 4l9 4.5-9 4.5-9-4.5Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" />
            <path d="M7 11v4.5c0 .8 2.2 2 5 2s5-1.2 5-2V11" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          </svg>
        </span>
        <span class="skills-panel-title" data-i18n="education.section.education">Education</span>
      </h3>
      <div class="skills-list">
        {% for item in educationSkills.education %}
        {% set entry = loop.index0 %}
        <div class="skills-list-item">
          <div class="skills-row">
            <strong data-i18n="education.entries.{{ entry }}.title">{{ item.title }}</strong>
            <span data-i18n="education.entries.{{ entry }}.date">{{ item.date }}</span>
          </div>
          <p data-i18n="education.entries.{{ entry }}.location">{{ item.location }}</p>
          <p data-i18n="education.entries.{{ entry }}.description">{{ item.description }}</p>
        </div>
        {% endfor %}
      </div>
    </article>

    <article class="skills-panel">
      <h3 class="skills-panel-heading">
        <span class="skills-panel-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="5" y="4.5" width="14" height="15" rx="2" fill="none" stroke="currentColor" stroke-width="1.7" />
            <path d="M9 9h6M9 13h6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          </svg>
        </span>
        <span class="skills-panel-title" data-i18n="education.section.courses">Courses</span>
      </h3>
      <div class="skills-list">
        {% for item in educationSkills.courses %}
        {% set course = loop.index0 %}
        <div class="skills-list-item">
          <div class="skills-row">
            <strong data-i18n="education.courses.{{ course }}.title">{{ item.title }}</strong>
            <span data-i18n="education.courses.{{ course }}.date">{{ item.date }}</span>
          </div>
          <p data-i18n="education.courses.{{ course }}.location">{{ item.location }}</p>
          <p data-i18n="education.courses.{{ course }}.description">{{ item.description }}</p>
        </div>
        {% endfor %}
      </div>
    </article>
  </div>
</section>
